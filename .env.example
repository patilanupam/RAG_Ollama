# ── Ollama Configuration ─────────────────────────────────────────
# RAG system uses Ollama for both embeddings and generation
# Supports local models and cloud models (after 'ollama signin')

# Ollama base URL (local daemon)
OLLAMA_BASE_URL=http://localhost:11434

# Model for text generation (options below)
# Cloud models (requires 'ollama signin'):
#   - deepseek-v3.1:671b-cloud  (recommended for quality)
#   - deepseek-r1:8b            (faster, smaller)
# Local models:
#   - qwen3:30b
#   - gemma3:27b
OLLAMA_MODEL=deepseek-v3.1:671b-cloud

# Model for embeddings (768 dimensions)
# Local model (free, no login required):
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Notes ─────────────────────────────────────────────────────────
# 1. Install Ollama: https://ollama.com/download
# 2. For cloud models, run: ollama signin
# 3. Start Ollama daemon (runs automatically on Windows/Mac)
# 4. No API key needed - daemon handles authentication
